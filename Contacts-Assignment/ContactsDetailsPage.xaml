<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Contacts_Assignment.ContactsDetailsPage"
             Title="Seagull Details"
             BackgroundColor="#FFF3F8">

    <ScrollView>

        <VerticalStackLayout
            Padding="25"
            Spacing="18">

            <Image
                x:Name="ContactImage"
                HeightRequest="220"
                WidthRequest="220"
                Aspect="AspectFill"
                HorizontalOptions="Center" />

            <Label
                x:Name="NameLabel"
                FontSize="30"
                FontAttributes="Bold"
                HorizontalTextAlignment="Center"
                TextColor="#6B2949" />

            <Label
                x:Name="EmailLabel"
                FontSize="18"
                TextColor="#6B2949" />

            <Label
                x:Name="PhoneLabel"
                FontSize="18"
                TextColor="#6B2949" />

            <Label
                x:Name="DescriptionLabel"
                FontSize="16"
                TextColor="#6B2949"
                LineBreakMode="WordWrap" />

            <Button
                Text="Back to the Flock"
                Clicked="BackButton_Clicked"
                BackgroundColor="#F48FB1"
                TextColor="White"
                CornerRadius="20" />

        </VerticalStackLayout>

    </ScrollView>

</ContentPage>