<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="Contacts_Assignment.MainPage"
    Title="Seagull Contacts"
    BackgroundColor="#FFF3F8">

    <Grid Padding="16">

        <CollectionView
            x:Name="ContactsCollectionView"
            IsGrouped="True"
            SelectionMode="Single"
            SelectionChanged="ContactsCollectionView_SelectionChanged">

            <CollectionView.GroupHeaderTemplate>
                <DataTemplate>
                    <Grid
                        Margin="0,14,0,5"
                        Padding="12,7"
                        BackgroundColor="#F8BBD4">

                        <Label
                            Text="{Binding GroupName}"
                            FontSize="22"
                            FontAttributes="Bold"
                            TextColor="#7A284F" />

                    </Grid>
                </DataTemplate>
            </CollectionView.GroupHeaderTemplate>

            <CollectionView.ItemTemplate>
                <DataTemplate>

                    <Border
                        Margin="0,6"
                        Padding="12"
                        BackgroundColor="White"
                        Stroke="#F3A9C8"
                        StrokeThickness="2"
                        StrokeShape="RoundRectangle 20">

                        <Grid
                            ColumnDefinitions="75,*"
                            ColumnSpacing="15">

                            <Border
                                WidthRequest="68"
                                HeightRequest="68"
                                BackgroundColor="#FFE3EF"
                                Stroke="#F3A9C8"
                                StrokeThickness="2"
                                StrokeShape="RoundRectangle 34">

                                <Image
                                    Source="{Binding Image}"
                                    Aspect="AspectFill" />

                            </Border>

                            <Label
                                Grid.Column="1"
                                Text="{Binding Name}"
                                FontSize="20"
                                FontAttributes="Bold"
                                TextColor="#6B2949"
                                VerticalOptions="Center" />

                        </Grid>

                    </Border>

                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

    </Grid>

</ContentPage>